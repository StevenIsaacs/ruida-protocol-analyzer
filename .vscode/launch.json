{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: rpa.py",
            "type": "debugpy",
            "request": "launch",
            "program": "rpa.py",
            "console": "externalTerminal",
            // "args": "${command:pickArgs}"
            "args": [
                "--verbose",
                "--raw",
                "--plot-moves",
                //"--input-encoding=utf-16",
                // "--stop-on-error",
                "-o",
                "discovery/selected.txt",
                "discovery/selected.log"
            ]
        },
        {
            "name": "Python Debugger: rpa-script (TUI)",
            "type": "debugpy",
            "request": "launch",
            "program": ".venv/bin/rpa-script",
            "console": "externalTerminal",
            // "args": "${command:pickArgs}"
            "args": [
                "--tui"
            ]
        }
    ]
}