#!/usr/bin/env bash
_self=$(basename "$0")
usage () {
  cat <<EOF
Usage: $_self <file> [<options>]

Use this script to run rpa.py to process a log file previously captured
by the capture script. The log file is processed three times. First to produce a
summarized decode, second to produce a verbose decode, and third to generate a
.rds script for round-trip verification.

The verbose decode generates an interactive Bokeh plot of all moves and cuts.
Requires a virtual environment with Bokeh installed. Create one from requirements.txt.

Parameters:
 1 The capture file name -- not including extension. Processes <file>.log.
    The output is written to <file>.txt, <file>-vrb.txt, and <file>.rds.
 2 Optional command line arguments for verbose mode. Often this will be used
    to generate a plot of all head movements. e.g.: "--plot-moves".
EOF
exit 1
}

if [ "$#" -lt 1 ]; then
    usage
fi

_file=$1
if [ ! -e $_file.log ]; then
    echo ERROR: The log file $_file.log does not exist.
    usage
fi

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Venv precedence:
#   1. $VIRTUAL_ENV if set (user-activated venv)
#   2. .venv/        (primary development venv)
#   3. .venv-bokeh/  (legacy migration venv)
if [[ -z "$VIRTUAL_ENV" ]]; then
    if [ -d "$_script_dir/.venv" ]; then
        source "$_script_dir/.venv/bin/activate"
    elif [ -d "$_script_dir/.venv-bokeh" ]; then
        source "$_script_dir/.venv-bokeh/bin/activate"
    else
        echo ERROR: No virtual environment found. Create one from requirements.txt.
        usage
    fi
fi

_rpa_cmd=rpa
command -v rpa >/dev/null 2>&1 || _rpa_cmd="python rpa.py"

$_rpa_cmd -o $_file.txt $_file.log
$_rpa_cmd --verbose --raw --unswizzled $2 -o $_file-vrb.txt $_file.log

$_rpa_cmd --generate-script $_file.log > /dev/null
