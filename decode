#!/usr/bin/env bash
_self=$(basename "$0")
usage () {
  cat <<EOF
Usage: $_self <file> [<options>]
       $_self --dir <directory> [<options>]

Use this script to run rpa.py to process a log file previously captured
by the capture script. The log file is processed four times. First to produce a
summarized decode, second to produce a verbose decode, third to generate a
.rds script for round-trip verification, and fourth to produce an interactive HTML plot.

The fourth pass generates an interactive Bokeh plot of all moves and cuts as a standalone HTML file.
Requires a virtual environment with Bokeh installed. Create one from requirements.txt.

Parameters:
  <file>       The capture file name -- without extension. Processes <file>.log or <file>.rd.
                Output written to <file>.txt, <file>-vrb.txt, <file>.rds, and <file>-plot.html.
                Use --rds-only to generate only the .rds file.
  --rds-only   Only generate the .rds script file, skipping other output files.
  --dir, -d    Recursively process all .log and .rd files in <directory> and its
               subdirectories. Each is processed as if passed individually as <file>.
  <options>    Optional arguments for verbose mode (e.g. "--plot-moves").
EOF
exit 1
}

# Parse --rds-only flag
_rds_only=false
_args=()
for _arg in "$@"; do
    if [ "$_arg" = "--rds-only" ]; then
        _rds_only=true
    else
        _args+=("$_arg")
    fi
done
set -- "${_args[@]}"

# Parse --dir flag
if [ "$1" = "--dir" ] || [ "$1" = "-d" ]; then
    _mode="dir"
    shift
    _dir="$1"
    if [ -z "$_dir" ] || [ ! -d "$_dir" ]; then
        echo "ERROR: Directory '$_dir' not found."
        usage
    fi
    shift
    shopt -s nullglob globstar
    _log_files=("$_dir"/**/*.log "$_dir"/**/*.rd)
    shopt -u nullglob
    if [ ${#_log_files[@]} -eq 0 ]; then
        echo "ERROR: No .log or .rd files found in $_dir."
        usage
    fi
else
    if [ "$#" -lt 1 ]; then
        usage
    fi
    _file=$1
    if [ -f "$_file.log" ]; then
        _log_files=("$_file")
    elif [ -f "$_file.rd" ]; then
        _log_files=("$_file")
    else
        echo "ERROR: Neither $_file.log nor $_file.rd exists."
        usage
    fi
    _mode="file"
fi

# Capture remaining options for verbose decode
_opts="${*:2}"  # default: single-file mode — skip file name
if [ "$_mode" = "dir" ]; then
    _opts="$*"  # dir mode: after shifts, $@ is all remaining options
fi

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Venv precedence:
#   1. $VIRTUAL_ENV if set (user-activated venv)
#   2. .venv/        (primary development venv)
#   3. .venv-bokeh/  (legacy migration venv)
if [[ -z "$VIRTUAL_ENV" ]]; then
    if [ -d "$_script_dir/.venv" ]; then
        source "$_script_dir/.venv/bin/activate"
    elif [ -d "$_script_dir/.venv-bokeh" ]; then
        source "$_script_dir/.venv-bokeh/bin/activate"
    else
        echo ERROR: No virtual environment found. Create one from requirements.txt.
        usage
    fi
fi

_rpa_cmd=rpa
command -v rpa >/dev/null 2>&1 || _rpa_cmd="python rpa.py"

_errors=0
_success=0
for _entry in "${_log_files[@]}"; do
    _base=""
    if [ "$_mode" = "dir" ]; then
        _base="${_entry%.*}"
        _name="${_entry##*/}"
        _ext="${_name##*.}"
        _suffix=""
        if [ "$_ext" = "log" ] && [ -f "${_base}.rd" ]; then
            _suffix="-log"
        elif [ "$_ext" = "rd" ] && [ -f "${_base}.log" ]; then
            _suffix="-rd"
        fi
        _base="${_base}${_suffix}"
        # Guard: skip if _base collides with an existing .log/.rd file
        # (input file has a double extension, e.g., foo.log.log → base=foo.log)
        _ext_of_base="${_base##*.}"
        if [ -f "$_base" ] && { [ "$_ext_of_base" = "log" ] || [ "$_ext_of_base" = "rd" ]; }; then
            echo "WARNING: Output base $_base collides with existing $_ext_of_base file. Skipping $_entry"
            continue
        fi
    else
        _base="$_entry"
        if [ -f "$_entry.log" ]; then
            _entry="$_entry.log"
        elif [ -f "$_entry.rd" ]; then
            _entry="$_entry.rd"
        else
            echo "ERROR: Input file for $_entry not found. Skipping."
            _errors=$((_errors + 1))
            continue
        fi
    fi

    if [ ! -f "$_entry" ]; then
        echo "ERROR: Input file $_entry not found. Skipping."
        _errors=$((_errors + 1))
        continue
    fi

    echo "=== Processing: $_entry ==="
    if ! $_rds_only; then
        $_rpa_cmd --quiet -o "$_base.txt" "$_entry" || { echo "ERROR: Simple decode failed for $_entry"; _errors=$((_errors + 1)); continue; }
        $_rpa_cmd --quiet --verbose --raw --unswizzled $_opts -o "$_base-vrb.txt" "$_entry" || { echo "ERROR: Verbose decode failed for $_entry"; _errors=$((_errors + 1)); continue; }
    fi
    $_rpa_cmd --quiet --generate-script -o "$_base" "$_entry" || { echo "ERROR: Script generation failed for $_entry"; _errors=$((_errors + 1)); continue; }
    if ! $_rds_only; then
        $_rpa_cmd --quiet --save-plot "$_entry" || true
    fi
    _success=$((_success + 1))
done

echo "=== Done: $_success processed, $_errors errors ==="
exit $_errors
